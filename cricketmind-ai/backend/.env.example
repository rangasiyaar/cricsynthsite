# CricketMind AI — Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (Primary LLM) — Free at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# CricketData.org API Key — Free at https://cricketdata.org/
CRICDATA_API_KEY=your_cricdata_api_key_here

# Groq API Key (Fallback LLM) — Free at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# App Configuration
LOG_LEVEL=INFO
PREDICTION_CACHE_HOURS=6
MAX_LLM_RETRIES=3

# Sportmonks Cricket API — Free at https://www.sportmonks.com/cricket-api/
SPORTMONKS_API_KEY=your_sportmonks_api_key_here

# Supabase — create a free project at supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis — create a free database at upstash.com
UPSTASH_REDIS_URL=redis://default:password@hostname:port

# ESPNcricinfo scraper — rate limit in seconds (default: 1.5)
ESPNCRICINFO_DELAY=1.5

# Data paths
CRICSHEET_DATA_DIR=./data/cricsheet
MAPPINGS_DIR=./data/mappings
